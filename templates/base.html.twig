<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}FrankenPHP on Clever Cloud{% endblock %}</title>

    <style>
      :root {
        --bg: #081226;
        --panel: #162338;
        --panel-soft: #1d2d46;
        --text: #f8fafc;
        --muted: #cbd5e1;
        --green: #22c55e;
        --blue: #38bdf8;
        --border: rgba(255, 255, 255, 0.08);
        --shadow: 0 18px 50px rgba(0, 0, 0, 0.35);
      }

      * {
        box-sizing: border-box;
      }

      html, body {
        margin: 0;
        padding: 0;
        min-height: 100%;
        font-family: Arial, sans-serif;
        background:
          radial-gradient(circle at top left, rgba(56, 189, 248, 0.18), transparent 28%),
          radial-gradient(circle at top right, rgba(34, 197, 94, 0.14), transparent 24%),
          linear-gradient(180deg, #081226 0%, #0b1730 100%);
        color: var(--text);
      }

      a {
        color: var(--blue);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      .container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 40px 20px 60px;
      }

      .hero,
      .card,
      .footer-card {
        background: rgba(22, 35, 56, 0.88);
        backdrop-filter: blur(4px);
        border: 1px solid var(--border);
        border-radius: 18px;
        box-shadow: var(--shadow);
      }

      .hero {
        padding: 32px;
        margin-bottom: 24px;
      }

      .eyebrow {
        display: inline-block;
        margin-bottom: 14px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(34, 197, 94, 0.12);
        color: #bbf7d0;
        font-size: 14px;
        font-weight: bold;
      }

      h1 {
        margin: 0 0 16px;
        font-size: 46px;
        line-height: 1.05;
        color: #ffffff;
      }

      .accent {
        color: var(--green);
      }

      .lead {
        margin: 0;
        max-width: 760px;
        font-size: 19px;
        line-height: 1.6;
        color: var(--muted);
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 28px;
      }

      .button {
        display: inline-block;
        padding: 12px 18px;
        border-radius: 10px;
        font-weight: bold;
        border: 1px solid transparent;
      }

      .button-primary {
        background: var(--green);
        color: #081226;
      }

      .button-secondary {
        background: rgba(56, 189, 248, 0.12);
        color: #e0f2fe;
        border-color: rgba(56, 189, 248, 0.3);
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 20px;
        margin-bottom: 24px;
      }

      .card {
        padding: 24px;
      }

      .col-4 {
        grid-column: span 4;
      }

      .col-6 {
        grid-column: span 6;
      }

      .col-8 {
        grid-column: span 8;
      }

      .col-12 {
        grid-column: span 12;
      }

      .card h2 {
        margin-top: 0;
        margin-bottom: 10px;
        font-size: 22px;
      }

      .card p,
      .card li {
        color: var(--muted);
        line-height: 1.6;
      }

      .metric {
        display: block;
        margin-top: 8px;
        font-size: 28px;
        font-weight: bold;
        color: #ffffff;
      }

      .metric-sub {
        display: block;
        margin-top: 8px;
        color: var(--muted);
        font-size: 14px;
      }

      .list {
        margin: 0;
        padding-left: 18px;
      }

      .logo-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 260px;
      }

      .logo-wrap img {
        max-width: 100%;
        height: auto;
      }

      .footer-card {
        padding: 20px 24px;
      }

      .footer-card p {
        margin: 0;
        color: var(--muted);
      }

      code {
        padding: 2px 6px;
        border-radius: 6px;
        background: rgba(2, 6, 23, 0.7);
        color: #e2e8f0;
      }

      @media (max-width: 900px) {
        h1 {
          font-size: 34px;
        }

        .col-4,
        .col-6,
        .col-8,
        .col-12 {
          grid-column: span 12;
        }
      }
    </style>

    {% block stylesheets %}{% endblock %}
    {% block javascripts %}{% endblock %}
  </head>
  <body>
    {% block body %}{% endblock %}
  </body>
</html>
