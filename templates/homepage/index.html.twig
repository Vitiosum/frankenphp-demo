{% extends 'base.html.twig' %}

{% block title %}FrankenPHP Demo | Clever Cloud{% endblock %}

{% block body %}

<style>

.container{
  max-width:1100px;
  margin:auto;
  padding:40px 20px;
  font-family:Arial, sans-serif;
}

.hero{
  background:#0f172a;
  color:white;
  padding:40px;
  border-radius:12px;
  margin-bottom:20px;
}

.hero h1{
  margin:0 0 10px 0;
  font-size:40px;
  color:#22c55e;
}

.hero p{
  color:#cbd5e1;
  font-size:18px;
}

.banner{
  background:#22c55e;
  color:#0f172a;
  font-weight:bold;
  display:inline-block;
  padding:8px 12px;
  border-radius:6px;
  margin-bottom:15px;
}

.logos{
  display:flex;
  align-items:center;
  gap:20px;
  margin-top:20px;
}

.logos img{
  height:45px;
}

.buttons{
  margin-top:25px;
}

.buttons a{
  text-decoration:none;
  font-weight:bold;
  padding:12px 18px;
  border-radius:8px;
  margin-right:10px;
  display:inline-block;
}

.btn-primary{
  background:#22c55e;
  color:#0f172a;
}

.btn-secondary{
  background:#38bdf8;
  color:#0f172a;
}

.grid{
  display:grid;
  grid-template-columns:1fr 1fr 1fr;
  gap:15px;
}

.card{
  background:#1e293b;
  color:white;
  padding:20px;
  border-radius:10px;
}

.card h2{
  margin-top:0;
}

.footer{
  margin-top:25px;
  color:#94a3b8;
}

@media (max-width:900px){
  .grid{
    grid-template-columns:1fr;
  }
}

</style>


<div class="container">

<div class="hero">

<div class="banner">
🎥 YouTube Demo — Running on Clever Cloud
</div>

<h1>FrankenPHP on Clever Cloud</h1>

<p>
This demo shows a modern PHP application using
<strong>FrankenPHP</strong>, <strong>Symfony</strong> and
<strong>API Platform</strong>, deployed on <strong>Clever Cloud</strong>.
</p>

<div class="logos">

<img src="https://www.clever.cloud/app/themes/Starter/assets/img/press/logos/clever-cloud-logo-white.svg">

<span style="font-size:26px;">+</span>

<img src="https://frankenphp.dev/img/frankenphp.png">

</div>

<div class="buttons">

<a class="btn-primary" href="/api" target="_blank">
Open Swagger UI
</a>

<a class="btn-secondary" href="/api/monsters.jsonld" target="_blank">
Open Monsters API
</a>

</div>

</div>


<div class="grid">

<div class="card">
<h2>Runtime</h2>
<p>
FrankenPHP provides a modern PHP runtime optimized for
performance and developer experience.
</p>
</div>

<div class="card">
<h2>Framework</h2>
<p>
Symfony structures the application while API Platform
automatically exposes documented API endpoints.
</p>
</div>

<div class="card">
<h2>Platform</h2>
<p>
Clever Cloud manages deployment, hosting and execution
so developers can focus on their applications.
</p>
</div>

</div>


<div class="footer">
Powered by FrankenPHP, Symfony and API Platform — deployed on
<a href="https://www.clever.cloud" target="_blank">Clever Cloud</a>.
</div>

</div>

{% endblock %}
